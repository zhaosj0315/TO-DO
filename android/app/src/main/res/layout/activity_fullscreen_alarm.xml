<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF5252"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- 顶部图标 -->
        <ImageView
            android:id="@+id/alarm_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:tint="#FFFFFF" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/alarm_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/alarm_icon"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:text="🚨 紧急任务提醒"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 任务信息卡片 -->
        <LinearLayout
            android:id="@+id/task_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/alarm_title"
            android:layout_marginTop="24dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="4dp">

            <!-- 任务名称 -->
            <TextView
                android:id="@+id/task_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 任务名称"
                android:textColor="#666"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/alarm_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="任务内容"
                android:textColor="#333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 分类和优先级 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/task_category"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💼 工作"
                    android:textColor="#666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/task_priority"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ 高优先级"
                    android:textColor="#666"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 任务类型 -->
            <TextView
                android:id="@+id/task_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="📅 今天"
                android:textColor="#666"
                android:textSize="14sp" />

            <!-- 截止时间 -->
            <TextView
                android:id="@+id/task_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="⏰ 截止：今天 23:59"
                android:textColor="#FF5252"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 创建时间 -->
            <TextView
                android:id="@+id/task_created"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🕐 创建于：2026-02-24 20:00"
                android:textColor="#999"
                android:textSize="12sp" />

            <!-- 任务描述 -->
            <TextView
                android:id="@+id/task_description_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 任务描述"
                android:textColor="#666"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/task_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="详细描述内容"
                android:textColor="#666"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 按钮容器 -->
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/task_info_card"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- 完成按钮 -->
            <Button
                android:id="@+id/btn_complete"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="#4CAF50"
                android:text="✅ 完成任务"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 稍后提醒按钮 -->
            <Button
                android:id="@+id/btn_snooze"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="#FF9800"
                android:text="⏰ 10分钟后提醒"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <!-- 关闭按钮 -->
            <Button
                android:id="@+id/btn_dismiss"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#757575"
                android:text="❌ 关闭"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

    </RelativeLayout>
</ScrollView>
